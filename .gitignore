# Environments
.venv/
.venv-hamer/
__pycache__/
*.pyc

# Cloned upstream model repo (WiLoR) — large weights, separate license, redownloadable
wilor/

# OS
.DS_Store

# Raw 4-min recordings and h264 streams — too large for GitHub (>100MB).
# Kept locally in repo root; switch to git-lfs if you ever need to track them.
/cam0.mp4
/cam1.mp4
*.h264

# Full stitched panorama is ~300MB — track sample frame in outputs/ instead.
/outputs/*stitched panorama.mp4

# 60-s WiLoR stereo demo render is ~150MB; keep the .npz + perf trace instead.
/outputs/*wilor stereo demo 60s*.mp4

# MediaPipe model — re-downloadable, not source.
*.task
